@model IEnumerable<PUMASTER>

@{
    ViewData["Title"] = "Registro de PU electronico";
}

<!-- CDN Bootstrap 5 + DataTables -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="container-fluid mb-4 mt-3 p-4 rounded-3 shadow-lg bg-light form-animado">
    <div class="row">
        <h2>REGISTROS</h2>
        <hr class="border border-dark border-0 mb-4 opacity-100">
    </div>

    <div class="row mt-1 mb-4">
        <div class="col-12">
             <a href="/Inspeccion/Crear" class="btn btn-success rounded-pill">➕ Nuevo Registro</a>
        </div>
        
    </div>

    <form method="get" asp-action="Index">
        <div class="row mb-4">
            <div class="col-md-2">
                <strong>Extruder:</strong>
            
                    <select name="extruder" class="form-select rounded-pill">
                        <option value="">-- Todos --</option>
                        @foreach (var extruder in ViewBag.Extruders as List<string>)
                        {
                            if (extruder == ViewBag.SelectedExtruder)
                            {
                                <option value="@extruder" selected>@extruder</option>
                            }
                            else
                            {
                                <option value="@extruder">@extruder</option>
                            }
                        }
                    </select>
            </div>

            <div class="col-md-2">
                <strong>Fecha:</strong>
                <input type="date" name="fecha" class="form-control rounded-pill"
                       value="@ViewBag.SelectedFecha" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary rounded-pill">Filtrar</button>
            </div>

        </div>
    </form>
    @if (Model != null && Model.Any())
    {
        <div class="row dt-row mt-3">
            <div class="table-responsive col-sm-12">

                <table id="Pu" class="table table-striped table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th>TM</th>
                            <th>Turno</th>
                            <th>Fecha/Hora</th>
                            <th>Extruder</th>
                            <th>Familia</th>
                            <th>Mandril</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item?.NOMBRE (@item?.NRO_EMPLEADO)</td>
                                <td>@item?.TURNO</td>
                                <td>@item?.FECHA.ToShortDateString() / @item?.HORA.ToString(@"hh\:mm")</td>
                                <td>@item?.EXTRUDER</td>
                                <td>@item?.FAMILIA</td>
                                <td>@item?.MANDRIL</td>

                                <td>
                                    <button class="btn btn-sm btn-primary btn-detalle rounded-pill"
                                            data-id="@item.ID">
                                        Ver detalles
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    }
    else
    {
        <p>No hay inspecciones registradas.</p>
    }
</div>

@section Scripts {

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {

            // Inicializar DataTables
            var table = $('#Pu').DataTable({
                pageLength: 10,
                order: [],
                language: {
                    url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });

            // Evento para cargar detalles usando child rows
            $('#Pu tbody').on('click', '.btn-detalle', function () {

                var tr = $(this).closest('tr');
                var row = table.row(tr);
                var id = $(this).data("id");

                // Si ya está abierto, lo cerramos
                if (row.child.isShown()) {
                    row.child.hide();
                    tr.removeClass('shown');
                    return;
                }

                // Mostrar spinner mientras carga
                row.child('<div class="text-center p-3"><div class="spinner-border text-primary"></div></div>').show();
                tr.addClass('shown');

                // Cargar partial por AJAX
                $.ajax({
                    url: "/Home/Detalle",   // <-- Ajusta si tu controlador es Inspeccion
                    type: "GET",
                    data: { id: id },
                    success: function (html) {
                        row.child(html).show();
                    },
                    error: function () {
                        row.child("<p class='text-danger p-3'>Error al cargar detalles.</p>").show();
                    }
                });

            });

        });
    </script>
}
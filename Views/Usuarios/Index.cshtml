@model IEnumerable<USERS>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="container-md mb-4 mt-3 p-4 rounded-3 shadow-lg bg-white form-animado">
    <div class="row">
        <h2>TEAM MEMBERS</h2>
        <hr class="border border-dark border-0 mb-4 opacity-100">
    </div>

    <div class="row mt-2">
        <div class="col-12">
        <button class="btn btn-success mb-3 rounded-pill" data-bs-toggle="modal" data-bs-target="#createEditModal" onclick="openCreateModal()">
            <i class="bi bi-person-plus"></i>
            Nuevo Team Member
        </button>
         </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row dt-row mt-2">
            <div class="table">
                <table id="TeamMembers" class="table table-striped table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th>Team Member</th>
                            <th>Role</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr data-id="@item.ID">
                                <td>@item.NOMBRE (@item.ID)</td>
                                <td>@item.ROL</td>
                                <td>
                                    <button class="btn btn-danger btn-sm rounded-pill"
                                            onclick="openDeleteModal(@item.ID)">
                                        <i class="bi bi-trash"></i> Borrar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <p>No hay TM registrados.</p>
    }
</div>

<!-- Modal Crear/Editar Team Member -->
<div class="modal fade" id="createEditModal" tabindex="-1" aria-labelledby="createEditModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createEditModalLabel">Nuevo Team Member</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="teamMemberForm" method="post" action="/Usuarios/Create">
                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label">Numero Empleado</label>
                        <input type="text" name="ID" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" name="NOMBRE" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Rol</label>
                        <input type="text" name="ROL" class="form-control" required />
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success rounded-pill">Guardar</button>
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Confirmación Eliminar -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirmar Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>¿Seguro que deseas eliminar este Team Member?</p>
                <input type="hidden" id="deleteId" />
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirmDelete" class="btn btn-danger">Eliminar</button>
            </div>

        </div>
    </div>
</div>


@section Scripts {

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {

            $('#TeamMembers').DataTable({
                pageLength: 10,
                order: [],
                language: {
                    url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });

        });

        let deleteId = null;

        function openDeleteModal(id) {
            deleteId = id;
            document.getElementById("deleteId").value = id;
            var modal = new bootstrap.Modal(document.getElementById("deleteConfirmModal"));
            modal.show();
        }

        document.getElementById("btnConfirmDelete").addEventListener("click", function () {
            if (!deleteId) return;

            fetch('/Usuarios/Delete/' + deleteId, {
                method: 'POST'
            })
            .then(response => {
                if (response.ok) {
                    // Cerrar modal
                    var modal = bootstrap.Modal.getInstance(document.getElementById("deleteConfirmModal"));
                    modal.hide();

                    // Eliminar fila en DataTable
                    var table = $('#TeamMembers').DataTable();
                    table.row($(`tr[data-id="${deleteId}"]`)).remove().draw();

                    deleteId = null;
                } else {
                    alert("Error al eliminar el registro.");
                }
            })
            .catch(err => {
                console.error(err);
                alert("Error de conexión.");
            });
        });

        // Inicializar DataTable
        $(document).ready(function () {
            $('#TeamMembers').DataTable();
        });


    </script>
}
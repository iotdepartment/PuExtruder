@model PUMASTER
@{
    ViewData["Title"] = "Registro de Medidas PU Extruder";
}

<form asp-action="Crear" method="post" class="form-animado">
    <div class="container mt-3 shadow-lg p-4 mb-5 bg-white rounded-3">
        @if (TempData["Mensaje"] != null)
        {
            var tipo = TempData["TipoMensaje"]?.ToString() ?? "info";
            <div class="alert alert-@tipo alert-dismissible fade show" role="alert">
                @TempData["Mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <h2>REGISTRO DE MEDIDAS PU EXTRUDER</h2>
        <hr class="border border-dark border-0 mb-4 opacity-100">

        <div class="row">
            <!-- Columna 1: DATOS GENERALES -->
            <div class="col-3">
                <h5 class="text-primary border-bottom pb-2 mb-3">DATOS GENERALES</h5>

                <div class="row mb-2 align-items-center">
                    <div class="col-4"><label for="NRO_EMPLEADO" class="form-label"># TM:</label></div>
                    <div class="col-8">
                        <select asp-for="NRO_EMPLEADO" asp-items="ViewBag.EmpleadoList" class="form-control" id="empleadoSelect">
                            <option value="">- Selecciona Empleado -</option>
                        </select>
                        <span asp-validation-for="NRO_EMPLEADO" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-4"><label for="NOMBRE" class="form-label"></label>NOMBRE:</div>
                    <div class="col-8"><input asp-for="NOMBRE" class="form-control" id="nombreEmpleado" readonly /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-4"><label for="TURNO" class="form-label">TURNO:</label></div>
                    <div class="col-8">
                        <select asp-for="TURNO" asp-items="ViewBag.ShiftList" class="form-control">
                            <option value="">- Selecciona Turno -</option>
                        </select>
                    </div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-4"><label for="EXTRUDER" class="form-label">EXTRUDER:</label></div>
                    <div class="col-8">
                        <select asp-for="EXTRUDER" asp-items="ViewBag.ExtruderList" class="form-control" id="extruderSelect">
                            <option value="">- Selecciona Extruder -</option>
                        </select>
                    </div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-4"><label for="FAMILIA" class="form-label">FAMILIA:</label></div>
                    <div class="col-8">
                        <select asp-for="FAMILIA" class="form-control" id="familiaSelect">
                            <option value="">- Selecciona Familia -</option>
                        </select>
                    </div>
                </div>


                <div class="row mb-2 align-items-center">
                    <div class="col-4"><label for="MANDRIL" class="form-label">MANDRIL:</label></div>
                    <div class="col-8">
                        <select asp-for="MANDRIL" class="form-control" id="mandrilSelect">
                            <option value="">- Selecciona Mandril -</option>
                        </select>
                    </div>
                </div>


            </div>

            <!-- Columna 2: PRIMERA PIEZA -->
            <div class="col-4">
                <h5 class="text-primary border-bottom pb-2 mb-3">PRIMERA PIEZA</h5>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="ID_A" class="form-label">ID:</label></div>
                    <div class="col-6"><input asp-for="ID_A" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="LONGITUD_A" class="form-label">LONGITUD:</label></div>
                    <div class="col-6"><input asp-for="LONGITUD_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED12_A" class="form-label">PARED 12:</label></div>
                    <div class="col-6"><input asp-for="PARED12_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED3_A" class="form-label">PARED 3:</label></div>
                    <div class="col-6"><input asp-for="PARED3_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED6_A" class="form-label">PARED 6:</label></div>
                    <div class="col-6"><input asp-for="PARED6_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED9_A" class="form-label">PARED 9:</label></div>
                    <div class="col-6"><input asp-for="PARED9_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PITCH_A" class="form-label">PITCH:</label></div>
                    <div class="col-6"><input asp-for="PITCH_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED_INTERNA_A" class="form-label">PARED INTERNA:</label></div>
                    <div class="col-6"><input asp-for="PARED_INTERNA_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED_EXTERNA_A" class="form-label">PARED EXTERNA:</label></div>
                    <div class="col-6"><input asp-for="PARED_EXTERNA_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="LONGITUD_LEYENDA_A" class="form-label">LONG. LEYENDA:</label></div>
                    <div class="col-6"><input asp-for="LONGITUD_LEYENDA_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="GROSOR_LEYENDA_A" class="form-label">GROSOR LEYENDA:</label></div>
                    <div class="col-6"><input asp-for="GROSOR_LEYENDA_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PESO_A" class="form-label">PESO:</label></div>
                    <div class="col-6"><input asp-for="PESO_A" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="LOGO_A" class="form-label">LEYENDA:</label></div>
                    <div class="col-6">
                        <select asp-for="LOGO_A" asp-items="ViewBag.LogoList" class="form-control">
                            <option value="">- ¿Leyenda Correcta? -</option>
                        </select>
                        <span id="logoAFeedback" class="text-danger"></span>
                    </div>
                </div>
            </div>

            

            <!-- Columna 3: ULTIMA PIEZA -->
            <div class="col-4">
                <h5 class="text-primary border-bottom pb-2 mb-3">ULTIMA PIEZA</h5>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="ID_B" class="form-label">ID:</label></div>
                    <div class="col-6"><input asp-for="ID_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="LONGITUD_B" class="form-label">LONGITUD:</label></div>
                    <div class="col-6"><input asp-for="LONGITUD_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED12_B" class="form-label">PARED 12:</label></div>
                    <div class="col-6"><input asp-for="PARED12_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED3_B" class="form-label">PARED 3</label></div>
                    <div class="col-6"><input asp-for="PARED3_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED6_B" class="form-label">PARED 6:</label></div>
                    <div class="col-6"><input asp-for="PARED6_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED9_B" class="form-label">PARED 9:</label></div>
                    <div class="col-6"><input asp-for="PARED9_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PITCH_B" class="form-label">PITCH:</label></div>
                    <div class="col-6"><input asp-for="PITCH_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED_INTERNA_B" class="form-label">PARED INTERNA:</label></div>
                    <div class="col-6"><input asp-for="PARED_INTERNA_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PARED_EXTERNA_B" class="form-label">PARED EXTERNA:</label></div>
                    <div class="col-6"><input asp-for="PARED_EXTERNA_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="LONGITUD_LEYENDA_B" class="form-label">LONG. LEYENDA</label></div>
                    <div class="col-6"><input asp-for="LONGITUD_LEYENDA_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="GROSOR_LEYENDA_B" class="form-label">GROSOR LEYENDA</label></div>
                    <div class="col-6"><input asp-for="GROSOR_LEYENDA_B" class="form-control" type="number" step="any"/></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="PESO_B" class="form-label">PESO:</label></div>
                    <div class="col-6"><input asp-for="PESO_B" class="form-control" type="number" step="any" /></div>
                </div>

                <div class="row mb-2 align-items-center">
                    <div class="col-6"><label for="LOGO_B" class="form-label">LEYENDA:</label></div>
                    <div class="col-6">
                        <select asp-for="LOGO_B" asp-items="ViewBag.LogoList" class="form-control">
                            <option value="">- ¿Leyenda Correcta?-</option>
                        </select>
                        <span id="logoAFeedback" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="col-1">
                <h5 class="text-primary border-bottom pb-2 mb-3">NOMINAL</h5>

                <div class="row mb-4">
                    @* <div class="col-8">ID:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_id"></span></div>
                </div>

                <div class="row mb-4">
                    @* <div class="col-8">LONGITUD:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_longitud"></span></div>
                </div>

                <div class="row mb-4">
                    @* <div class="col-8">PARED 12:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_pared12"></span></div>
                </div>

                <div class="row mb-4">
                    @* <div class="col-8">PARED 3:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_pared3"></span></div>
                </div>

                <div class="row mb-4">
                    @* <div class="col-8">PARED 6:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_pared6"></span></div>
                </div>

                <div class="row mb-4">
                    @* <div class="col-8">PARED 9:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_pared9"></span></div>
                </div>

                <div class="row mb-4">
                    @* <div class="col-8">PITCH:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_pitch"></span></div>
                </div>

                <div class="row mb-4">
                    @* <div class="col-8">PARED INTERNA:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_paredInterna"></span></div>
                </div>

                <div class="row mb-4">
                    @* <div class="col-9">PARED EXTERNA:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_paredExterna"></span></div>
                </div>

                <div class="row mb-4">
                    @* <div class="col-8">LONG. LEYENDA:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_longLeyenda"></span></div>
                </div>

                <div class="row mb-4">
                    @* <div class="col-9">GROSOR LEYENDA:</div> *@
                    <div class="col-12 d-flex justify-content-center text-success fw-bold"><span id="param_grosorLeyenda"></span></div>
                </div>
            </div>
        </div>

        <!-- Comentarios -->
        <div class="row mt-3">
            <div class="col-md-12">
                <div class="row align-items-center">
                    <div class="col-2"><label for="COMENTARIOS" class="form-label">COMENTARIOS:</label></div>
                    <div class="col-10"><textarea asp-for="COMENTARIOS" class="form-control" rows="3"></textarea></div>
                </div>
            </div>
        </div>

        <!-- Botones -->
        <div class="row mt-3">
            <div class="col-md-12 text-end">
                <button type="submit" class="btn btn-success px-4 me-2 shadow-sm rounded-pill">Guardar</button>
                <button type="reset" class="btn btn-secondary px-4 me-2 rounded-pill">Limpiar</button>
                <a asp-action="Index" asp-controller="Home" class="btn btn-info px-4 rounded-pill">Mostrar Registros</a>
            </div>
        </div>
    </div>
</form>

<!-- Script para copiar el nombre del empleado cuando se selecciona el numero del mismo -->
@section Scripts {
    <script>
        document.getElementById("empleadoSelect").addEventListener("change", function () {
            var id = this.value;
            if (id) {
                fetch(`/Inspeccion/ObtenerNombreEmpleado?id=${id}`)
                    .then(response => response.json())
                    .then(data => {
                        document.getElementById("nombreEmpleado").value = data.nombre;
                    });
            } else {
                document.getElementById("nombreEmpleado").value = "";
            }
        });

        $(document).ready(function () {
            // Cuando cambia el extruder, actualiza familias
            $("#extruderSelect").change(function () {
                var extruder = $(this).val();
                $("#familiaSelect").empty();
                $("#familiaSelect").append('<option value="">-- Selecciona Familia --</option>');
                $("#mandrilSelect").empty();
                $("#mandrilSelect").append('<option value="">-- Selecciona Mandril --</option>');

                if (extruder) {
                    $.getJSON('/Inspeccion/GetFamiliasByExtruder', { extruder: extruder }, function (data) {
                        $.each(data, function (i, familia) {
                            $("#familiaSelect").append('<option value="' + familia + '">' + familia + '</option>');
                        });
                    });
                }
            });

            // Cuando cambia la familia, actualiza mandriles
            $("#familiaSelect").change(function () {
                var extruder = $("#extruderSelect").val();
                var familia = $(this).val();
                $("#mandrilSelect").empty();
                $("#mandrilSelect").append('<option value="">-- Selecciona Mandril --</option>');

                if (extruder && familia) {
                    $.getJSON('/Inspeccion/GetMandriles', { extruder: extruder, familia: familia }, function (data) {
                        $.each(data, function (i, mandril) {
                            $("#mandrilSelect").append('<option value="' + mandril + '">' + mandril + '</option>');
                        });
                    });
                }
            });
        });

        $(document).ready(function () {
            $("#mandrilSelect").change(function () {
                var extruder = $("#extruderSelect").val();
                var familia = $("#familiaSelect").val();
                var mandril = $(this).val();

                if (extruder && familia && mandril) {
                    $.getJSON('/Inspeccion/GetParametros',
                              { extruder: extruder, familia: familia, mandril: mandril },
                              function (data) {
                        if (data) {
                            $("#param_id").text(data.iD_);
                            $("#param_longitud").text(data.longituD_CORTE);
                            $("#param_pared12").text(data.pared); 
                            $("#param_pared3").text(data.pared);
                            $("#param_pared6").text(data.pared);
                            $("#param_pared9").text(data.pared);
                            $("#param_pitch").text(data.pitch);
                            $("#param_paredInterna").text(data.inneR_YARN);
                            $("#param_paredExterna").text(data.outeR_YARN);
                            $("#param_longLeyenda").text(data.longituD_LEYENDA);
                            $("#param_grosorLeyenda").text(data.grosoR_LEYENDA);
                        } else {
                            $(".col-2 span").text(""); 
                        }
                    });
                }
            });
        });

        $(document).ready(function () {
            var parametros = {};

            // Al seleccionar mandril, guardamos los nominales y tolerancias
            $("#mandrilSelect").change(function () {
                var extruder = $("#extruderSelect").val();
                var familia = $("#familiaSelect").val();
                var mandril = $(this).val();

                if (extruder && familia && mandril) {
                    $.getJSON('/Inspeccion/GetParametros',
                              { extruder: extruder, familia: familia, mandril: mandril },
                              function (data) {
                        if (data) {
                            parametros = data; // guardamos todo el objeto JSON
                        }
                    });
                }
            });

            // Función genérica de validación
            function validarCampo(inputId, nominal, tol) {
                var valorIngresado = parseFloat($(inputId).val());
                if (nominal != null && tol != null && !isNaN(valorIngresado)) {
                    var min = nominal - tol;
                    var max = nominal + tol;

                    if (valorIngresado >= min && valorIngresado <= max) {
                        $(inputId).removeClass("is-invalid").addClass("is-valid");
                    } else {
                        $(inputId).removeClass("is-valid").addClass("is-invalid");
                    }
                } else {
                    $(inputId).removeClass("is-valid is-invalid");
                }
            }


            // Validaciones en tiempo real

            $("#ID_A").on("input", function () {
                validarCampo("#ID_A", parametros.iD_, parametros.iD_TOL);
            });

            $("#LONGITUD_A").on("input", function () {
                validarCampo("#LONGITUD_A", parametros.longituD_CORTE, parametros.longituD_CORTE_TOL);
            });

            $("#PARED12_A").on("input", function () {
                validarCampo("#PARED12_A", parametros.pared, parametros.pareD_TOL);
            });

            $("#PARED3_A").on("input", function () {
                validarCampo("#PARED3_A", parametros.pared, parametros.pareD_TOL);
            });

            $("#PARED6_A").on("input", function () {
                validarCampo("#PARED6_A", parametros.pared, parametros.pareD_TOL);
            });

            $("#PARED9_A").on("input", function () {
                validarCampo("#PARED9_A", parametros.pared, parametros.pareD_TOL);
            });

            $("#PITCH_A").on("input", function () {
                validarCampo("#PITCH_A", parametros.pitch, parametros.pitcH_TOL);
            });

            $("#PARED_INTERNA_A").on("input", function () {
                validarCampo("#PARED_INTERNA_A", parametros.inneR_YARN, parametros.inneR_YARN_TOL);
            });

            $("#PARED_EXTERNA_A").on("input", function () {
                validarCampo("#PARED_EXTERNA_A", parametros.outeR_YARN, parametros.outeR_YARN_TOL);
            });

            $("#LONGITUD_LEYENDA_A").on("input", function () {
                validarCampo("#LONGITUD_LEYENDA_A", parametros.longituD_LEYENDA, parametros.longituD_LEYENDA_TOL);
            });

            $("#GROSOR_LEYENDA_A").on("input", function () {
                validarCampo("#GROSOR_LEYENDA_A", parametros.grosoR_LEYENDA, parametros.grosoR_LEYENDA_TOL);
            });


            $("#ID_B").on("input", function () {
                validarCampo("#ID_B", parametros.iD_, parametros.iD_TOL);
            });

            $("#LONGITUD_B").on("input", function () {
                validarCampo("#LONGITUD_B", parametros.longituD_CORTE, parametros.longituD_CORTE_TOL);
            });

            $("#PARED12_B").on("input", function () {
                validarCampo("#PARED12_B", parametros.pared, parametros.pareD_TOL);
            });

            $("#PARED3_B").on("input", function () {
                validarCampo("#PARED3_B", parametros.pared, parametros.pareD_TOL);
            });

            $("#PARED6_B").on("input", function () {
                validarCampo("#PARED6_B", parametros.pared, parametros.pareD_TOL);
            });

            $("#PARED9_B").on("input", function () {
                validarCampo("#PARED9_B", parametros.pared, parametros.pareD_TOL);
            });

            $("#PITCH_B").on("input", function () {
                validarCampo("#PITCH_B", parametros.pitch, parametros.pitcH_TOL);
            });

            $("#PARED_INTERNA_B").on("input", function () {
                validarCampo("#PARED_INTERNA_B", parametros.inneR_YARN, parametros.inneR_YARN_TOL);
            });

            $("#PARED_EXTERNA_B").on("input", function () {
                validarCampo("#PARED_EXTERNA_B", parametros.outeR_YARN, parametros.outeR_YARN_TOL);
            });

            $("#LONGITUD_LEYENDA_B").on("input", function () {
                validarCampo("#LONGITUD_LEYENDA_B", parametros.longituD_LEYENDA, parametros.longituD_LEYENDA_TOL);
            });

            $("#GROSOR_LEYENDA_B").on("input", function () {
                validarCampo("#GROSOR_LEYENDA_B", parametros.grosoR_LEYENDA, parametros.grosoR_LEYENDA_TOL);
            });

        });

        $(document).ready(function () {
            function validarLogo(selectId, feedbackId) {
                var valor = $(selectId).val();
                if (valor === "SI") {
                    $(selectId).removeClass("is-invalid").addClass("is-valid");
                } else {
                    $(selectId).removeClass("is-valid").addClass("is-invalid");
                }
            }

            // Validación en tiempo real
            $("#LOGO_A").on("change", function () {
                validarLogo("#LOGO_A", "#logoAFeedback");
            });

            $("#LOGO_B").on("change", function () {
                validarLogo("#LOGO_B", "#logoBFeedback");
            });
        });

        document.addEventListener("DOMContentLoaded", function () {
            var alertEl = document.querySelector('.alert');
            if (alertEl) {
                setTimeout(function () {
                    var alert = bootstrap.Alert.getOrCreateInstance(alertEl);
                    alert.close();
                }, 2000); // 5 segundos
            }
        });

    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
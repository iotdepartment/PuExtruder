@model IEnumerable<TOLERANCES>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="container-fluid mb-4 mt-3 p-4 rounded-3 shadow-lg bg-white form-animado">
    <div class="row">
        <h2>Mandriles</h2>
        <hr class="border border-dark border-0 mb-4 opacity-100">
    </div>

    <div class="row mt-2">
        <div class="col-12">
            <button class="btn btn-success mb-3" data-bs-toggle="modal" data-bs-target="#createEditModal" onclick="openCreateModal()">
                <i class="bi bi-person-plus"></i>
                Nuevo Mandril
            </button>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="row dt-row mt-2">
                <div class="table">
                    <table id="TeamMembers" class="table table-striped table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Extruder</th>
                                <th>Mandril</th>
                                <th>Familia</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.EXTRUDER</td>
                                    <td>@item.MANDRIL</td>
                                    <td>@item.FAMILIA</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary btn-detalle"
                                                data-id="@item.ID">
                                            Ver detalles
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <p>No hay Mandriles registrados.</p>
        }
    </div>
</div>

<div class="modal fade" id="createEditModal" tabindex="-1" aria-labelledby="createEditModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createEditModalLabel">Nuevo Mandril</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="teamMemberForm" method="post" action="/Tolerances/Create">
                <div class="modal-body">

                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Datos Generales</h5>
                            <div class="row mb-1">
                                <div class="col-10">
                                    <label class="form-label">Mandril:</label>
                                    <input type="text" name="MANDRIL" class="form-control" required />
                                </div>
                            </div>
                            <div class="row mb-1">
                                <div class="col-10">
                                <label class="form-label">Extruder:</label>
                                <select name="EXTRUDER" class="form-control" required>
                                    <option value="">-- Seleccione Extruder --</option>
                                    <option value="EXTRUDER 1">EXTRUDER 1</option>
                                    <option value="EXTRUDER 2">EXTRUDER 2</option>
                                    <option value="EXTRUDER 3">EXTRUDER 3</option>
                                    <option value="EXTRUDER 4">EXTRUDER 4</option>
                                    <option value="EXTRUDER 5">EXTRUDER 5</option>
                                    <option value="EXTRUDER 6">EXTRUDER 6</option>
                                </select>
                                </div>
                            </div>
                            <div class="row mb-1">
                                <div class="col-10">
                                    <label class="form-label">Familia:</label>
                                    <input type="text" name="FAMILIA" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- ID -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Diametro Interno</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="text" name="ID_" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="text" name="ID_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- LONGITUD CORTE -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Longitud de Corte</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="text" name="LONGITUD_CORTE" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="text" name="LONGITUD_CORTE_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- PARED -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Paredes</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="text" name="PARED" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="text" name="PARED_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                        <!-- PITCH -->
                            <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                                <h5 class="mb-2 fw-bold">Pitch</h5>
                                <div class="row">
                                    <div class="col-6">
                                        <label class="form-label">Nominal:</label>
                                        <input type="text" name="PITCH" class="form-control" required />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Tolerancia:</label>
                                        <input type="text" name="PITCH_TOL" class="form-control" required />
                                    </div>
                                </div>
                            </div>

                    <!-- Pared Interna -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Pared Interna</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="text" name="INNER_YARN" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="text" name="INNER_YARN_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- Pared Externa -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Pared Externa</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="text" name="OUTER_YARN" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="text" name="OUTER_YARN_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- Longitud leyenda -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Longitud Leyenda</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="text" name="LONGITUD_LEYENDA" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="text" name="LONGITUD_LEYENDA_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- Grosor leyenda -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Grosor Leyenda</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="text" name="GROSOR_LEYENDA" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="text" name="GROSOR_LEYENDA_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {

            // Inicializar DataTable
            var table = $('#TeamMembers').DataTable({
                pageLength: 10,
                order: [],
                language: {
                    url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });

            // Evento para cargar detalles usando child rows
            $('#TeamMembers tbody').on('click', '.btn-detalle', function () {

                var tr = $(this).closest('tr');
                var row = table.row(tr);
                var id = $(this).data("id");

                // Si ya está abierto, lo cerramos
                if (row.child.isShown()) {
                    row.child.hide();
                    tr.removeClass('shown');
                    return;
                }

                // Mostrar spinner mientras carga
                row.child('<div class="text-center p-3"><div class="spinner-border text-primary"></div></div>').show();
                tr.addClass('shown');

                // Cargar partial por AJAX
                $.ajax({
                    url: "/Tolerances/Detalle",
                    type: "GET",
                    data: { id: id },
                    success: function (html) {
                        row.child(html).show();
                    },
                    error: function () {
                        row.child("<p class='text-danger p-3'>Error al cargar detalles.</p>").show();
                    }
                });

            });

        });
    </script>
}

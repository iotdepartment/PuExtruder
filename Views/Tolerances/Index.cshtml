@model IEnumerable<TOLERANCES>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="container-fluid mb-4 mt-3 p-4 rounded-3 shadow-lg bg-white form-animado">
    <div class="row">
        <h2>MANDRILES</h2>
        <hr class="border border-dark border-0 mb-4 opacity-100">
    </div>

    <div class="row mt-2">
        <div class="col-12">
            <button class="btn btn-success mb-3 rounded-pill" data-bs-toggle="modal" data-bs-target="#createEditModal" onclick="openCreateModal()">
                <i class="bi bi-person-plus"></i>
                Nuevo Mandril
            </button>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="row dt-row mt-2">
                <div class="table">
                    <table id="Mandriles" class="table table-striped table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Extruder</th>
                                <th>Mandril</th>
                                <th>Familia</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.EXTRUDER</td>
                                    <td>@item.MANDRIL</td>
                                    <td>@item.FAMILIA</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary btn-detalle rounded-pill"
                                                data-id="@item.ID">
                                            Ver detalles
                                        </button>

                                        <button class="btn btn-sm btn-warning btn-edit rounded-pill"
                                                data-id="@item.ID">
                                            Modificar
                                        </button>


                                        <button class="btn btn-sm btn-danger btn-delete rounded-pill"
                                                data-id="@item.ID">
                                            Eliminar
                                        </button>

                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <p>No hay Mandriles registrados.</p>
        }
    </div>
</div>

<div class="modal fade" id="createEditModal" tabindex="-1" aria-labelledby="createEditModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createEditModalLabel">Nuevo Mandril</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="MandrilForm" method="post" action="/Tolerances/Create">
                <div class="modal-body">
                    
                    <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                        <h5 class="mb-2 fw-bold">Datos Generales</h5>
                        <div class="row mb-1">
                            <div class="col-4 align-items-end">
                                <label class="form-label">Mandril:</label>
                                <div class="input-group">
                                    <input type="text" name="MANDRIL" class="form-control" maxlength="4" oninput="this.value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '')" required />
                                    <span class="input-group-text">-MX</span>
                                </div>
                            </div>
                        
                            <div class="row mb-1">
                                <div class="col-4">
                                    <label class="form-label">Extruder:</label>
                                    <select id="extruderSelect" name="EXTRUDER" class="form-control" required>
                                        <option value="">-- Seleccione Extruder --</option>
                                        <option value="Extruder 1">Extruder 1</option>
                                        <option value="Extruder 2">Extruder 2</option>
                                        <option value="Extruder 3">Extruder 3</option>
                                        <option value="Extruder 4">Extruder 4</option>
                                        <option value="Extruder 5">Extruder 5</option>
                                        <option value="Extruder 6">Extruder 6</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-1">
                                <div class="col-4">
                                    <label class="form-label">Familia:</label>
                                    <select id="familiaSelect" name="FAMILIA" class="form-control" required>
                                        <option value="">-- Seleccione Familia --</option>
                                    </select>
                                </div>
                            </div>

                        </div>
                    </div>
                    <!-- ID -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Diametro Interno</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="number" step="any" name="ID_" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="number" step="any" name="ID_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- LONGITUD CORTE -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Longitud de Corte</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="number" step="any" name="LONGITUD_CORTE" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="number" step="any" name="LONGITUD_CORTE_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- PARED -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Paredes</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="number" step="any" name="PARED" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="number" step="any" name="PARED_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                        <!-- PITCH -->
                            <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                                <h5 class="mb-2 fw-bold">Pitch</h5>
                                <div class="row">
                                    <div class="col-6">
                                        <label class="form-label">Nominal:</label>
                                        <input type="number" step="any" name="PITCH" class="form-control" required />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Tolerancia:</label>
                                        <input type="number" step="any" name="PITCH_TOL" class="form-control" required />
                                    </div>
                                </div>
                            </div>

                    <!-- Pared Interna -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Pared Interna</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="number" step="any" name="INNER_YARN" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="number" step="any" name="INNER_YARN_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- Pared Externa -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Pared Externa</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="number" step="any" name="OUTER_YARN" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="number" step="any" name="OUTER_YARN_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- Longitud leyenda -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Longitud Leyenda</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="number" step="any" name="LONGITUD_LEYENDA" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="number" step="any" name="LONGITUD_LEYENDA_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                    <!-- Grosor leyenda -->
                        <div class="parameter-box mb-3 p-3 border rounded shadow-sm">
                            <h5 class="mb-2 fw-bold">Grosor Leyenda</h5>
                            <div class="row">
                                <div class="col-6">
                                    <label class="form-label">Nominal:</label>
                                    <input type="number" step="any" name="GROSOR_LEYENDA" class="form-control" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Tolerancia:</label>
                                    <input type="number" step="any" name="GROSOR_LEYENDA_TOL" class="form-control" required />
                                </div>
                            </div>
                        </div>

                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success rounded-pill">Guardar</button>
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button> 
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Confirmación Eliminar -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirmar Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>¿Seguro que deseas eliminar este mandril?</p>
                <input type="hidden" id="deleteId" />
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirmDelete" class="btn btn-danger">Eliminar</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {

            // Inicializar DataTable
            var table = $('#Mandriles').DataTable({
                pageLength: 10,
                order: [],
                language: {
                    url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });

            // Evento para cargar detalles usando child rows
            $('#Mandriles tbody').on('click', '.btn-detalle', function () {

                var tr = $(this).closest('tr');
                var row = table.row(tr);
                var id = $(this).data("id");

                // Si ya está abierto, lo cerramos
                if (row.child.isShown()) {
                    row.child.hide();
                    tr.removeClass('shown');
                    return;
                }

                // Mostrar spinner mientras carga
                row.child('<div class="text-center p-3"><div class="spinner-border text-primary"></div></div>').show();
                tr.addClass('shown');

                // Cargar partial por AJAX
                $.ajax({
                    url: "/Tolerances/Detalle",
                    type: "GET",
                    data: { id: id },
                    success: function (html) {
                        row.child(html).show();
                    },
                    error: function () {
                        row.child("<p class='text-danger p-3'>Error al cargar detalles.</p>").show();
                    }
                });

            });

        });

         // Evento para cargar el modal para editar registros
                $(document).on("click", ".btn-edit", function () {
            const id = $(this).data("id");

            // Cambiar título del modal
            $("#createEditModalLabel").text("Editar Mandril");

            // Cambiar acción del formulario
              $("#MandrilForm").attr("action", "/Tolerances/Update");

            // Guardar ID en un campo oculto (si no existe, créalo)
            if ($("#editId").length === 0) {
                  $("#MandrilForm").append('<input type="hidden" id="editId" name="ID" />');
            }
            $("#editId").val(id);

            // Cargar datos vía AJAX
            $.ajax({
                url: "/Tolerances/GetById",
                type: "GET",
                data: { id: id },
                success: function (data) {

                    // Rellenar campos
                    $("input[name='MANDRIL']").val(data.mandril);
                    $("input[name='EXTRUDER']").val(data.extruder);
                    $("input[name='FAMILIA']").val(data.familia);

                    $("input[name='ID_']").val(data.iD_);
                    $("input[name='ID_TOL']").val(data.iD_TOL);

                    $("input[name='LONGITUD_CORTE']").val(data.longituD_CORTE);
                    $("input[name='LONGITUD_CORTE_TOL']").val(data.longituD_CORTE_TOL);

                    $("input[name='PARED']").val(data.pared);
                    $("input[name='PARED_TOL']").val(data.pareD_TOL);

                    $("input[name='PITCH']").val(data.pitch);
                    $("input[name='PITCH_TOL']").val(data.pitcH_TOL);

                    $("input[name='INNER_YARN']").val(data.inneR_YARN);
                    $("input[name='INNER_YARN_TOL']").val(data.inneR_YARN_TOL);

                    $("input[name='OUTER_YARN']").val(data.outeR_YARN);
                    $("input[name='OUTER_YARN_TOL']").val(data.outeR_YARN_TOL);

                    $("input[name='LONGITUD_LEYENDA']").val(data.longituD_LEYENDA);
                    $("input[name='LONGITUD_LEYENDA_TOL']").val(data.longituD_LEYENDA_TOL);

                    $("input[name='GROSOR_LEYENDA']").val(data.grosoR_LEYENDA);
                    $("input[name='GROSOR_LEYENDA_TOL']").val(data.grosoR_LEYENDA_TOL);

                    // Abrir modal
                    $("#createEditModal").modal("show");
                }
            });
        });

      // Evento para cargar el modal para confirmar eliminar registro
        $(document).on("click", ".btn-delete", function () {
            const id = $(this).data("id");
            $("#deleteId").val(id);
            $("#deleteConfirmModal").modal("show");
        });

        $("#btnConfirmDelete").on("click", function () {
            const id = $("#deleteId").val();

            $.ajax({
                url: "/Tolerances/Delete",
                type: "POST",
                data: { id: id },
                success: function (response) {
                    $("#deleteConfirmModal").modal("hide");
                    location.reload();
                },
                error: function () {
                    alert("Error al eliminar el registro.");
                }
            });
        });

        document.getElementById("extruderSelect").addEventListener("change", function () {
            var extruder = this.value;
            var familiaSelect = document.getElementById("familiaSelect");

            // Limpiar opciones previas
            familiaSelect.innerHTML = '<option value="">-- Seleccione Familia --</option>';

            if (extruder) {
                fetch('/TOLERANCES/GetFamilias?extruder=' + encodeURIComponent(extruder))
                    .then(response => response.json())
                    .then(data => {
                        data.forEach(familia => {
                            var option = document.createElement("option");
                            option.value = familia;
                            option.text = familia;
                            familiaSelect.appendChild(option);
                        });
                    });
            }
        });



    </script>
}
